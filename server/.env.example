# ─── MongoDB ───────────────────────────────────────────
# Get this from MongoDB Atlas: Database > Connect > Drivers
MONGODB_URI=mongodb://username:password@cluster.mongodb.net/mydb?retryWrites=true&w=majority

# ─── JWT Authentication ────────────────────────────────
# Generate a random secure string (e.g. openssl rand -hex 32)
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRE=30d

# ─── Server ────────────────────────────────────────────
PORT=5000

# ─── Google Gemini AI ──────────────────────────────────
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your gemini api key"
